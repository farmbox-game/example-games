<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Ever-Farm Sim</title>
    <style>
        body { background: #222; color: white; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; }
        #game-container { position: relative; width: 600px; height: 600px; background: #2e7d32; border: 4px solid #5d4037; overflow: hidden; margin-top: 20px; }
        .tile { position: absolute; width: 50px; height: 50px; border: 0.1px solid rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .player { position: absolute; width: 50px; height: 50px; background: rgba(0,0,255,0.5); border-radius: 50%; z-index: 10; transition: all 0.1s; display: flex; align-items: center; justify-content: center; }
        #ui { width: 600px; display: flex; justify-content: space-between; padding: 10px; background: #333; }
        .night-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,50,0.5); pointer-events: none; visibility: hidden; }
        .stats { background: #444; padding: 10px; border-radius: 5px; margin-bottom: 10px; width: 600px; }
    </style>
</head>
<body>

    <div class="stats" id="status-bar">
        Day: <span id="day-count">1</span> | Season: <span id="season">Spring</span> | Points: <span id="points">100</span>
    </div>

    <div id="game-container">
        <div id="grid"></div>
        <div id="player" class="player">👩‍🌾</div>
        <div id="night-mask" class="night-overlay"></div>
    </div>

    <div id="ui">
        <div>Seeds: <span id="seed-count">5</span> | Tasks: <span id="task-list">Plant Wheat</span></div>
        <button onclick="interact()">Interact (E)</button>
        <button onclick="sleep()" id="sleep-btn" style="display:none;">Sleep (Z)</button>
    </div>

<script>
    // --- Configuration ---
    const GRID_SIZE = 12;
    const TILE_SIZE = 50;
    let playerPos = { x: 1, y: 1 };
    let gameState = {
        day: 1,
        timeInDay: 0, 
        isNight: false,
        season: 'Spring',
        points: 100,
        seeds: 5,
        inventory: []
    };

    const gridData = [];

    // --- Initialization ---
    function initGrid() {
        const gridEl = document.getElementById('grid');
        for (let y = 0; y < GRID_SIZE; y++) {
            for (let x = 0; x < GRID_SIZE; x++) {
                let type = 'grass';
                let content = '';
                
                // Starting layout
                if (x === 0 && y === 0) { type = 'house'; content = '🏠'; }
                else if (x === 2 && y === 2) { type = 'tilled'; content = ''; }
                else if (x > 8 && y > 8) { type = 'pasture'; content = '🐑'; }

                const tile = { x, y, type, water: 0, crop: null, age: 0 };
                gridData.push(tile);

                const div = document.createElement('div');
                div.id = `tile-${x}-${y}`;
                div.className = 'tile';
                div.style.left = `${x * TILE_SIZE}px`;
                div.style.top = `${y * TILE_SIZE}px`;
                div.style.backgroundColor = getTileColor(type);
                div.innerText = content;
                gridEl.appendChild(div);
            }
        }
    }

    function getTileColor(type) {
        switch(type) {
            case 'house': return '#795548';
            case 'tilled': return '#5d4037';
            case 'pasture': return '#9ccc65';
            default: return '#2e7d32';
        }
    }

    // --- Movement ---
    window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowUp' && playerPos.y > 0) playerPos.y--;
        if (e.key === 'ArrowDown' && playerPos.y < GRID_SIZE - 1) playerPos.y++;
        if (e.key === 'ArrowLeft' && playerPos.x > 0) playerPos.x--;
        if (e.key === 'ArrowRight' && playerPos.x < GRID_SIZE - 1) playerPos.x++;
        if (e.key === 'e') interact();
        if (e.key === 'z' && gameState.isNight) sleep();
        updatePlayer();
    });

    function updatePlayer() {
        const p = document.getElementById('player');
        p.style.left = `${playerPos.x * TILE_SIZE}px`;
        p.style.top = `${playerPos.y * TILE_SIZE}px`;
    }

    // --- Core Mechanics ---
    function interact() {
        const tile = gridData.find(t => t.x === playerPos.x && t.y === playerPos.y);
        
        if (tile.type === 'tilled' && !tile.crop && gameState.seeds > 0) {
            tile.crop = 'wheat';
            tile.age = 0;
            gameState.seeds--;
            renderTile(tile, '🌱');
        } else if (tile.crop && tile.age >= 3) {
            // Harvest
            tile.crop = null;
            gameState.points += 20;
            renderTile(tile, '');
            updateUI();
        }
    }

    function renderTile(tile, emoji) {
        const el = document.getElementById(`tile-${tile.x}-${tile.y}`);
        el.innerText = emoji;
    }

    // --- Time Management ---
    function gameLoop() {
        if (!gameState.isNight) {
            gameState.timeInDay += 1;
            if (gameState.timeInDay >= 600) { // 10 minutes = 600 seconds
                triggerNight();
            }
        }
    }

    function triggerNight() {
        gameState.isNight = true;
        document.getElementById('night-mask').style.visibility = 'visible';
        document.getElementById('sleep-btn').style.display = 'block';
    }

    function sleep() {
        gameState.day++;
        gameState.isNight = false;
        gameState.timeInDay = 0;
        document.getElementById('night-mask').style.visibility = 'hidden';
        document.getElementById('sleep-btn').style.display = 'none';
        
        // Age crops
        gridData.forEach(t => {
            if (t.crop) {
                t.age++;
                if (t.age === 2) renderTile(t, '🌿');
                if (t.age === 3) renderTile(t, '🌾');
                if (t.age > 5) { t.crop = null; renderTile(t, '🍂'); } // Died
            }
        });
        
        updateUI();
    }

    function updateUI() {
        document.getElementById('day-count').innerText = gameState.day;
        document.getElementById('points').innerText = gameState.points;
        document.getElementById('seed-count').innerText = gameState.seeds;
    }

    initGrid();
    updatePlayer();
    setInterval(gameLoop, 1000);

</script>
</body>
</html>
